{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Productos de la boutique"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "mujer",
        "hombre"
      ],
      "required": true
    },
    "subcategory": {
      "type": "enumeration",
      "enum": [
        "Blusas",
        "Vestidos",
        "Pantalones",
        "Playeras",
        "Camisas",
        "Faldas",
        "Chaquetas",
        "Bolsos",
        "Calzado",
        "Trajes de baño",
        "Accesorios"
      ],
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "sizes": {
      "type": "json",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "whatsapp": {
      "type": "string",
      "default": "50255550000"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    },
    "sku": {
      "type": "string"
    },
    "oldPrice": {
      "type": "decimal",
      "min": 0
    },
    "availability": {
      "type": "enumeration",
      "enum": [
        "available",
        "low_stock",
        "out_of_stock",
        "pre_order"
      ],
      "default": "available"
    },
    "newArrival": {
      "type": "boolean",
      "default": false
    },
    "onSale": {
      "type": "boolean",
      "default": false
    },
    "colors": {
      "type": "json"
    },
    "tags": {
      "type": "json"
    },
    "cat": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "subcat": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subcategory.subcategory",
      "inversedBy": "products"
    }
  }
}
